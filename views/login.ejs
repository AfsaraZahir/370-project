<% title = 'Login - PizzApp'; css = ['/css/auth.css']; %>
<%- include('partials/head') %>
  <body>
    <!-- Login page body: shows the login form to return users -->

    <!-- Login and Signup Forms -->
    <div class="container d-flex justify-content-center align-items-center min-height-100vh auth-card">
        <div class = "card p-4 shadow signup-card" style="width: 100%; max-width: 400px;">
            <h2 class="text-center mb-4">Login to PizzApp</h2>
            <!-- Show feedback messages from the server -->
            <% if (typeof query !== 'undefined' && query.error) { %>
  <div class="alert alert-danger text-center">
    <%= query.error %>
  </div>
<% } %>

<% if (typeof query !== 'undefined' && query.success) { %>
  <div class="alert alert-success text-center">
    <%= query.success %>
  </div>
<% } %>
            <!-- Login form sends email and password to the server -->
            <form action="/login" method="POST">
                <div class="mb-3">
                    <label for="email" class="form-label">Email address</label>
                    <input type="email" class="form-control" id="email" placeholder="Enter your email" name="email">
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" id="password" placeholder="Enter your password" name="password">
                </div>
                <button type="submit" class="btn btn-primary w-100 mb-2">Login</button>
                <button type="button" class="btn btn-outline-success w-100" onclick="window.location.href='/signup'">Sign Up</button>
            </form>
        </div>
    </div>






    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
